# Safekeep CRM - Environment Configuration
# Copy this file to .env and fill in the values.

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL="postgresql://user:password@localhost:5432/safekeep_crm?schema=public"

# Auth.js (NextAuth v5) – required for sessions (app errors with MissingSecret if unset)
# Generate with: openssl rand -base64 32
AUTH_SECRET= bXJXUbxTrL6QlBMP97RXyG5Cwy38NoIN+CNVSyq2WTk=

# Optional: for production or custom config
# DIRECT_URL="postgresql://user:password@localhost:5432/safekeep_crm"

# Document storage (Phase 6). Default: ./storage (local filesystem)
# STORAGE_PATH="./storage"
